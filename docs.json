{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Zerion API",
  "colors": {
    "primary": "#3030D4",
    "light": "#3030D4",
    "dark": "#3030D4"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://dashboard.zerion.io",
          "icon": "square-terminal"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              {
                "group": "Build with AI",
                "pages": [
                  "build-with-ai/overview",
                  "build-with-ai/mcp",
                  "build-with-ai/x402",
                  "build-with-ai/zerion-skill"
                ]
              }
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "supported-blockchains",
              "endpoints-and-schema",
              "pagination-and-filtering",
              "error-handling",
              "rate-limits",
              "spam-filtering"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "REST API",
            "openapi": "openapi-v1.yaml"
          }
        ]
      },
      {
        "tab": "Recipes",
        "pages": [
          "recipes",
          "recipes/multi-chain-portfolio",
          "recipes/defi-positions",
          "recipes/wallet-token-balances",
          "recipes/transaction-history",
          "recipes/wallet-activity-alerts",
          "recipes/wallet-pnl-tracker",
          "recipes/nft-portfolio"
        ]
      },
      {
        "tab": "Changelogs",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://dashboard.zerion.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.zerion.io"
    }
  },
  "redirects": [
    { "source": "/reference/getting-started", "destination": "/introduction" },
    { "source": "/reference/authentication", "destination": "/authentication" },
    { "source": "/reference/supported-blockchains", "destination": "/supported-blockchains" },
    { "source": "/reference/endpoints-and-schema-details", "destination": "/endpoints-and-schema" },
    { "source": "/reference/error-codes", "destination": "/error-handling" },
    { "source": "/reference/token-spam-filtering", "destination": "/spam-filtering" },
    { "source": "/reference/building-with-ai", "destination": "/build-with-ai/overview" },
    { "source": "/reference/faqs", "destination": "/introduction" },
    { "source": "/reference/featured-partners", "destination": "/introduction" },
    { "source": "/reference/feedback", "destination": "/introduction" },
    { "source": "/reference/wallets", "destination": "/api-reference/wallets/get-wallet-portfolio" },
    { "source": "/reference/getwalletchart", "destination": "/api-reference/wallets/get-wallet-balance-chart" },
    { "source": "/reference/getwalletpnl", "destination": "/api-reference/wallets/get-wallet-pnl" },
    { "source": "/reference/getwalletportfolio", "destination": "/api-reference/wallets/get-wallet-portfolio" },
    { "source": "/reference/listwalletpositions", "destination": "/api-reference/wallets/get-wallet-fungible-positions" },
    { "source": "/reference/listwallettransactions", "destination": "/api-reference/wallets/get-wallet-transactions" },
    { "source": "/reference/listwalletnftpositions", "destination": "/api-reference/wallets/get-wallet-nft-positions" },
    { "source": "/reference/listwalletnftcollections", "destination": "/api-reference/wallets/get-wallet-nft-collections" },
    { "source": "/reference/getwalletnftportfolio", "destination": "/api-reference/wallets/get-wallet-nft-portfolio" },
    { "source": "/reference/fungibles", "destination": "/api-reference/fungibles/get-list-of-fungible-assets" },
    { "source": "/reference/listfungibles", "destination": "/api-reference/fungibles/get-list-of-fungible-assets" },
    { "source": "/reference/getfungiblebyid", "destination": "/api-reference/fungibles/get-fungible-asset-by-id" },
    { "source": "/reference/getfungiblebyimplementation", "destination": "/api-reference/fungibles/get-fungible-asset-by-implementation" },
    { "source": "/reference/getfungiblechart", "destination": "/api-reference/fungibles/get-a-chart-for-a-fungible-asset" },
    { "source": "/reference/getfungiblechartbyimplementation", "destination": "/api-reference/fungibles/get-a-chart-for-a-fungible-asset-by-implementation" },
    { "source": "/reference/chains", "destination": "/api-reference/chains/get-list-of-all-chains" },
    { "source": "/reference/listchains", "destination": "/api-reference/chains/get-list-of-all-chains" },
    { "source": "/reference/getchainbyid", "destination": "/api-reference/chains/get-chain-by-id" },
    { "source": "/reference/swapfungibles", "destination": "/api-reference/swap/get-fungibles-available-for-bridge" },
    { "source": "/reference/swapoffers", "destination": "/api-reference/swap/get-available-swap-offers" },
    { "source": "/reference/listgasprices", "destination": "/api-reference/gas/get-list-of-all-available-gas-prices" },
    { "source": "/reference/listnfts", "destination": "/api-reference/nfts/get-list-of-nfts" },
    { "source": "/reference/getnftbyid", "destination": "/api-reference/nfts/get-single-nft-by-id" },
    { "source": "/reference/findwallettransactionssubscription", "destination": "/api-reference/subscriptions-to-transactions/find-subscriptions" },
    { "source": "/reference/createsubscriptionwallettransactions", "destination": "/api-reference/subscriptions-to-transactions/create-subscription" },
    { "source": "/reference/getwallettransactionssubscription", "destination": "/api-reference/subscriptions-to-transactions/find-subscription-by-id" },
    { "source": "/reference/deletewallettransactionssubscription", "destination": "/api-reference/subscriptions-to-transactions/delete-subscription-by-id" },
    { "source": "/reference/getsubscribedwalletsinsubscription", "destination": "/api-reference/subscriptions-to-transactions/find-wallets-within-subscription" },
    { "source": "/reference/patchsubscribedwalletsinsubscription", "destination": "/api-reference/subscriptions-to-transactions/patch-wallets-within-subscription" },
    { "source": "/reference/replacesubscribedwalletsinsubscription", "destination": "/api-reference/subscriptions-to-transactions/replace-wallets-within-subscription" },
    { "source": "/reference/getsubscribedwalletscountinsubscription", "destination": "/api-reference/subscriptions-to-transactions/count-wallets-within-subscription" },
    { "source": "/reference/updatecallbackurlinsubscription", "destination": "/api-reference/subscriptions-to-transactions/update-callback-url-within-subscription" },
    { "source": "/reference/enablesubscription", "destination": "/api-reference/subscriptions-to-transactions/enable-a-specific-subscription" },
    { "source": "/reference/disablesubscription", "destination": "/api-reference/subscriptions-to-transactions/disable-a-specific-subscription" },
    { "source": "/reference/updatechainidsinsubscription", "destination": "/api-reference/subscriptions-to-transactions/update-chain-ids-within-subscription" },
    { "source": "/reference/listdapps", "destination": "/api-reference/dapps/get-list-of-dapps" },
    { "source": "/reference/getdappbyid", "destination": "/api-reference/dapps/get-dapp-by-id" },
    { "source": "/recipes/building-a-real-time-asset-tracker-with-zerions-api", "destination": "/recipes/wallet-token-balances" },
    { "source": "/recipes/how-to-build-a-meta-dex-aggregator-0x-1inch-uniswap-more-price-sources-1", "destination": "/recipes" },
    { "source": "/recipes/how-to-build-a-multichain-transaction-history-like-zerion", "destination": "/recipes/transaction-history" },
    { "source": "/changelog/:slug*", "destination": "/changelog" }
  ],
  "integrations": {},
  "contextual": {
    "options": ["chatgpt", "claude"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/zerion"
    }
  },
  "fonts": {
    "heading": {
      "family": "Aeonik Pro",
      "weight": 700,
      "source": "/fonts/AeonikPro-VF.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Aeonik Pro",
      "weight": 400,
      "source": "/fonts/AeonikPro-VF.woff2",
      "format": "woff2"
    }
  },
  "description": "Zerion is an Ethereum and Solana wallet and developer platform focused on making blockchain data easy to use."
}
